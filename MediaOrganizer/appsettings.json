{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": false
      }
    }
  },
  "MediaOrganizer": {
    "SourceDirectory": "C:\\YourLocal\\Source",
    "DestinationDirectory": "C:\\YourLocal\\Destination", 
    "DryRun": true,
    "IncludeSubdirectories": true,
    "TvShowPathTemplate": "{TvShowName}/Season {Season}/{TvShowName} - S{Season:D2}E{Episode:D2}"
  }
}