{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": false
      }
    }
  },
  "MediaOrganizer": {
    "SourceDirectory": "C:\\YourLocal\\Source",
    "DestinationDirectory": "C:\\YourLocal\\Destination", 
    "TvShowSourceDirectory": "C:\\YourLocal\\TvShows\\Source",
    "TvShowDestinationDirectory": "C:\\YourLocal\\TvShows\\Organized",
    "MovieSourceDirectory": "C:\\YourLocal\\Movies\\Source",
    "MovieDestinationDirectory": "C:\\YourLocal\\Movies\\Organized",
    "DryRun": true,
    "IncludeSubdirectories": true,
    "TvShowPathTemplate": "{TvShowName}/Season {Season}/{TvShowName} - S{Season:D2}E{Episode:D2}",
    "MoviePathTemplate": "{Title} ({Year})/{Title} {Quality}",
    "VideoFileExtensions": [
      ".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".3gp"
    ],
    "AutoCleanupEmptyDirectories": false,
    "IgnoredFolders": [
      "Featurettes", "Extras", "Behind the Scenes", "Deleted Scenes", "Bonus Features", "Special Features"
    ]
    },
    "TmdbApi": {
      "ApiKey": "",
      "BaseUrl": "https://api.themoviedb.org/3"
    }
}